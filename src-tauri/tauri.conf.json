{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "pjvpin",
  "version": "0.1.0",
  "identifier": "com.upic.pjupi",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "pjvpin",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; base-uri 'self'; img-src 'self' asset: https://asset.localhost data:; font-src 'self' data:; connect-src 'self' https://api.decolecta.com https://renacyt.concytec.gob.pe https://servicio-renacyt.concytec.gob.pe https://pure.unf.edu.pe"
    }
  },
  "bundle": {
    "active": true,
    "targets": "nsis",
    "useLocalToolsDir": true,
    "resources": {},
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "offlineInstaller",
        "silent": true
      },
      "nsis": {
        "installMode": "currentUser"
      }
    }
  }
}
