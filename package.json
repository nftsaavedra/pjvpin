{
  "name": "pjvpin",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "check": "npm run lint && npm run typecheck",
    "tauri": "tauri",
    "tauri:build:exe": "powershell -ExecutionPolicy Bypass -File ./scripts/tauri-build.ps1 --no-bundle",
    "tauri:build:portable": "powershell -ExecutionPolicy Bypass -File ./scripts/tauri-build-portable.ps1",
    "tauri:build:installer": "powershell -ExecutionPolicy Bypass -File ./scripts/tauri-build.ps1",
    "tauri:build:nsis": "powershell -ExecutionPolicy Bypass -File ./scripts/tauri-build.ps1 --bundles nsis",
    "tauri:build:msi": "powershell -ExecutionPolicy Bypass -File ./scripts/tauri-build.ps1 --bundles msi"
  },
  "dependencies": {
    "@floating-ui/react": "^0.27.19",
    "@react-pdf/renderer": "^4.4.0",
    "@tailwindcss/vite": "^4.3.0",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "^2.7.0",
    "@tauri-apps/plugin-opener": "^2",
    "exceljs": "^4.4.0",
    "lucide-react": "^1.7.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "recharts": "^3.8.1",
    "tailwindcss": "^4.3.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tauri-apps/cli": "^2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@types/recharts": "^1.8.29",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "jsdom": "^29.1.1",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.1",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  }
}
